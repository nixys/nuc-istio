{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "nuc-istio values",
  "description": "Schema for nuc-istio Helm chart values.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Enable rendering for this subchart."
    },
    "global": {
      "type": "object",
      "default": {},
      "description": "Compatibility values inherited from umbrella charts.",
      "additionalProperties": true
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in generated labels."
    },
    "commonLabels": {
      "$ref": "#/definitions/stringMap",
      "description": "Labels merged into every rendered resource."
    },
    "commonAnnotations": {
      "$ref": "#/definitions/stringMap",
      "description": "Annotations merged into every rendered resource."
    },
    "generic": {
      "type": "object",
      "description": "Shared generic values compatible with nxs-universal-chart.",
      "additionalProperties": true,
      "properties": {
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "apiVersions": {
      "type": "object",
      "description": "Default API version overrides per supported Istio kind.",
      "additionalProperties": false,
      "properties": {
        "authorizationPolicy": { "$ref": "#/definitions/nonEmptyString" },
        "destinationRule": { "$ref": "#/definitions/nonEmptyString" },
        "envoyFilter": { "$ref": "#/definitions/nonEmptyString" },
        "gateway": { "$ref": "#/definitions/nonEmptyString" },
        "peerAuthentication": { "$ref": "#/definitions/nonEmptyString" },
        "proxyConfig": { "$ref": "#/definitions/nonEmptyString" },
        "requestAuthentication": { "$ref": "#/definitions/nonEmptyString" },
        "serviceEntry": { "$ref": "#/definitions/nonEmptyString" },
        "sidecar": { "$ref": "#/definitions/nonEmptyString" },
        "telemetry": { "$ref": "#/definitions/nonEmptyString" },
        "virtualService": { "$ref": "#/definitions/nonEmptyString" },
        "wasmPlugin": { "$ref": "#/definitions/nonEmptyString" },
        "workloadEntry": { "$ref": "#/definitions/nonEmptyString" },
        "workloadGroup": { "$ref": "#/definitions/nonEmptyString" }
      }
    },
    "authorizationpolicies": { "$ref": "#/definitions/resourceMap" },
    "destinationrules": { "$ref": "#/definitions/resourceMap" },
    "envoyfilters": { "$ref": "#/definitions/resourceMap" },
    "gateways": { "$ref": "#/definitions/resourceMap" },
    "peerauthentications": { "$ref": "#/definitions/resourceMap" },
    "proxyconfigs": { "$ref": "#/definitions/resourceMap" },
    "requestauthentications": { "$ref": "#/definitions/resourceMap" },
    "serviceentries": { "$ref": "#/definitions/resourceMap" },
    "sidecars": { "$ref": "#/definitions/resourceMap" },
    "telemetries": { "$ref": "#/definitions/resourceMap" },
    "virtualservices": { "$ref": "#/definitions/resourceMap" },
    "wasmplugins": { "$ref": "#/definitions/resourceMap" },
    "workloadentries": { "$ref": "#/definitions/resourceMap" },
    "workloadgroups": { "$ref": "#/definitions/resourceMap" }
  },
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringMap": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "freeFormObject": {
      "type": "object",
      "additionalProperties": true
    },
    "resourceItem": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "namespace": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "apiVersion": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "spec": {
          "$ref": "#/definitions/freeFormObject"
        },
        "status": {
          "$ref": "#/definitions/freeFormObject"
        }
      }
    },
    "resourceMap": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "$ref": "#/definitions/nonEmptyString"
      },
      "additionalProperties": {
        "anyOf": [
          { "$ref": "#/definitions/resourceItem" },
          { "type": "null" }
        ]
      }
    }
  }
}
